# Ripple Engine — Environment Variables
# Copy this file to backend/.env and fill in your actual API keys.
# NEVER commit backend/.env to the repository.

# WeatherAPI — https://www.weatherapi.com/
WEATHER_API_KEY="your_weatherapi_key_here"

# World Air Quality Index — https://aqicn.org/api/
WAQI_API_KEY="your_waqi_api_key_here"

# GeoNames — https://www.geonames.org/export/web-services.html
GEONAMES_USERNAME="your_geonames_username_here"

# Gemini AI — https://aistudio.google.com/apikey
GEMINI_API_KEY="your_gemini_api_key_here"

# Optional: comma-separated list of allowed CORS origins
ALLOWED_ORIGINS="http://localhost:5500,http://127.0.0.1:5500"
